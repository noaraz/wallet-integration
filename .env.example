# Telegram
BOT_TOKEN=
WEBHOOK_SECRET=
ALLOWED_TG_USER_IDS=              # Comma-separated Telegram user IDs, e.g. 12345,67890

# Gemini (Phase 2 — vision extraction; OCR eval picked Gemini over Claude/Tesseract/Surya)
GEMINI_API_KEY=                   # https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash     # optional override; e.g. gemini-flash-latest to ride out outages

# Google Wallet (Phase 4)
WALLET_ISSUER_ID=
WALLET_CLASS_ID=
# In prod: WALLET_SA_KEY_JSON is mounted from Secret Manager.
# Locally: path to a downloaded service-account JSON file.
WALLET_SA_KEY_PATH=

# Runtime
PORT=8080
LOG_LEVEL=INFO
